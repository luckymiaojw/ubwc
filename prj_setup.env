#! /bin/csh
# source /App/env/digital.cshrc
set prompt="%/>>"

###########################################
### EDA TOOLS
if ( -d $HOME/.openclaw/bin ) then
    set path=($path $HOME/.openclaw/bin)
endif

if ( -d $HOME/.local/eda/bin ) then
    set path=($path $HOME/.local/eda/bin)
endif

#coreConsultant
##TODO setenv DESIGNWARE_HOME /prj/work_area/atom/dw
##TODO set path=($path /prj/work_area/atom/dw/bin)
set path=($path /App/synopsys/coretools/S-2021.09-SP4-1/bin)

# nLint
##TODO set path = ( $path /eda_tools/nlint_vK-2015.09/bin)

# verdi
set path =($path /App/synopsys/verdi/S-2021.09-SP2/bin)
setenv VERDI_HOME /App/synopsys/verdi/S-2021.09-SP2

# VCS
set path=($path /App/synopsys/vcs/S-2021.09-SP2/bin)
setenv VCS_HOME /App/synopsys/vcs/S-2021.09-SP2

# VERA
##TODO setenv VERA_HOME /eda_tools/vera_vI-2014.03-2.auth/vera_vI-2014.03-2_amd64
##TODO set path = ( $path $VERA_HOME/bin )

setenv LM_LICENSE_FILE /home/eda/license/synopsys.dat

echo "##################################################################"
echo "################  Server Setting DONE          ###################"
echo "##################################################################"

##########################################
### PROJECT SETUP
setenv PROJECT_HOME `pwd`
setenv HDL_PATH $PROJECT_HOME/src
setenv VER_PATH $PROJECT_HOME/vrf
setenv SIM_PATH $VER_PATH/sim
